# Auth.js secret – generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# The public URL of the app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0 credentials (REQUIRED)
# Create at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID (Azure AD) credentials (OPTIONAL) 
# Only provide these if you want to enable Microsoft sign-in
# Create at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Redirect URI: http://localhost:3000/api/auth/callback/azure-ad
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# Use "common" for multi-tenant or your specific tenant ID
# AZURE_AD_TENANT_ID=common
